{
  "name": "react-native-track-player",
  "version": "5.0.0-alpha0",
  "description": "A fully fledged audio module created for music apps. Local fork with playback diagnostic events.",
  "main": "./lib/module/index.js",
  "types": "./lib/typescript/src/index.d.ts",
  "exports": {
    ".": {
      "source": "./src/index.tsx",
      "types": "./lib/typescript/src/index.d.ts",
      "default": "./lib/module/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "src",
    "lib",
    "android",
    "ios",
    "*.podspec"
  ],
  "scripts": {
    "build": "react-native-builder-bob build",
    "clean": "rm -rf lib",
    "prepare": "echo 'Skipping build - lib/ is pre-built and committed'"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/doublesymmetry/react-native-track-player.git"
  },
  "peerDependencies": {
    "react": "*",
    "react-native": "*"
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      [
        "module",
        {
          "esm": true
        }
      ],
      [
        "typescript",
        {
          "project": "tsconfig.build.json",
          "tsc": "../../node_modules/.bin/tsc"
        }
      ]
    ]
  },
  "codegenConfig": {
    "name": "TrackPlayerSpec",
    "type": "modules",
    "jsSrcsDir": "src",
    "android": {
      "javaPackageName": "com.doublesymmetry.trackplayer"
    },
    "ios": {
      "modulesProvider": {
        "NativeTrackPlayer": "TrackPlayer"
      }
    }
  }
}
